# ──────────────────────────────────────────────────────────────────
#  LLM Provider  (choose one: openai | anthropic | azure_openai | groq | ollama)
# ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI (only needed when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Groq (LLM_PROVIDER=groq) ───────────────────────────────────────
# Free tier available at https://console.groq.com
# Fast inference of open-source models on Groq hardware.
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
# Other Groq models: llama-3.1-8b-instant  mixtral-8x7b-32768  gemma2-9b-it

# ── Ollama (LLM_PROVIDER=ollama) ───────────────────────────────────
# Requires Ollama running locally: https://ollama.com
# Pull a model first:  ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Other Ollama models: mistral  phi3  gemma2  qwen2.5  llama3.1

# ──────────────────────────────────────────────────────────────────
#  Self-Healing tuning
# ──────────────────────────────────────────────────────────────────
MAX_REPAIR_ATTEMPTS=3
HEALING_TIMEOUT_SECONDS=300
LEARNING_RATE=0.15

# ──────────────────────────────────────────────────────────────────
#  Memory
# ──────────────────────────────────────────────────────────────────
EPISODIC_MEMORY_LIMIT=1000
SEMANTIC_MEMORY_K=5
MEMORY_DB_PATH=data/memory.db

# ──────────────────────────────────────────────────────────────────
#  Knowledge Graph
# ──────────────────────────────────────────────────────────────────
KG_DB_PATH=data/knowledge_graph.pkl

# ──────────────────────────────────────────────────────────────────
#  Persistence
# ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/agents.db

# ──────────────────────────────────────────────────────────────────
#  API Server
# ──────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ──────────────────────────────────────────────────────────────────
#  Logging
# ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console    # json | console
